{
  "name": "agt-pme-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:next": "next dev -p 3000",
    "dev:hub": "cross-env NEXT_PUBLIC_SECTOR=hub next dev -p 3000",
    "dev:restaurant": "cross-env NEXT_PUBLIC_SECTOR=restaurant next dev -p 3001",
    "dev:banking": "cross-env NEXT_PUBLIC_SECTOR=banking next dev -p 3002",
    "dev:clinical": "cross-env NEXT_PUBLIC_SECTOR=clinical next dev -p 3003",
    "dev:school": "cross-env NEXT_PUBLIC_SECTOR=school next dev -p 3004",
    "dev:ecommerce": "cross-env NEXT_PUBLIC_SECTOR=ecommerce next dev -p 3005",
    "dev:hotel": "cross-env NEXT_PUBLIC_SECTOR=hotel next dev -p 3006",
    "dev:public": "cross-env NEXT_PUBLIC_SECTOR=public next dev -p 3007",
    "dev:pme": "cross-env NEXT_PUBLIC_SECTOR=pme next dev -p 3008",
    "dev:transport": "cross-env NEXT_PUBLIC_SECTOR=transport next dev -p 3009",
    "dev:custom": "cross-env NEXT_PUBLIC_SECTOR=custom next dev -p 3000",
    "dev:api": "json-server --watch db/db.json --port 4000 --routes db/routes.json",
    "dev:mock": "concurrently \"next dev -p 3000\" \"json-server --watch db/db.json --port 4000 --routes db/routes.json\"",
    "dev:hub:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=hub next dev -p 3000",
    "dev:restaurant:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=restaurant next dev -p 3001",
    "dev:banking:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=banking next dev -p 3002",
    "dev:clinical:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=clinical next dev -p 3003",
    "dev:school:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=school next dev -p 3004",
    "dev:ecommerce:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=ecommerce next dev -p 3005",
    "dev:hotel:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=hotel next dev -p 3006",
    "dev:public:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=public next dev -p 3007",
    "dev:pme:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=pme next dev -p 3008",
    "dev:transport:mem": "cross-env NODE_OPTIONS=--max-old-space-size=1536 NEXT_PUBLIC_SECTOR=transport next dev -p 3009",
    "dev:all": "concurrently --kill-others-on-fail -n hub,resto,bank,clin,sch,ecom,hot,pub,pme,trans -c blue,magenta,yellow,red,cyan,green,gray,white,greenBright,blueBright \"npm:dev:hub:mem\" \"npm:dev:restaurant:mem\" \"npm:dev:banking:mem\" \"npm:dev:clinical:mem\" \"npm:dev:school:mem\" \"npm:dev:ecommerce:mem\" \"npm:dev:hotel:mem\" \"npm:dev:public:mem\" \"npm:dev:pme:mem\" \"npm:dev:transport:mem\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@react-oauth/google": "^0.12.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.400.0",
    "next": "^14.2.28",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "json-server": "^0.17.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.6",
    "typescript": "^5"
  },
  "description": "AGT-BOT – Interface PME"
}